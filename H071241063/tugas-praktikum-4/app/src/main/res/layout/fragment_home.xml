<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:text="Library"
            android:fontFamily="@font/sora_semibold"
            android:textSize="28sp"
            android:textColor="@color/text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_book_count"
            android:fontFamily="@font/sora_regular"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_search"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical">

        <TextView
            android:text="⌕"
            android:textSize="16sp"
            android:textColor="@color/text_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/et_search"
            android:hint="Cari buku atau penulis..."
            android:fontFamily="@font/sora_regular"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:background="@null"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>
    </LinearLayout>

    <!-- Genre Chips -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_genre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="10dp"
        app:singleSelection="true"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/divider"/>

    <!--
        ProgressBar: tampil saat background thread sedang berjalan (mencari/filter data).
        Disembunyikan (GONE) setelah data selesai diproses dan ditampilkan ke RecyclerView.
    -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="48dp"
        android:indeterminateTint="@color/text_primary"
        android:visibility="gone"
        android:layout_weight="0"/>

    <!-- Book List: disembunyikan saat loading, tampil setelah data siap -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_books"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:clipToPadding="false"/>

</LinearLayout>