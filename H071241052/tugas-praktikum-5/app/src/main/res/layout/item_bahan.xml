<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/pink_soft">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/vStatusIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/circle_indicator"
            android:backgroundTint="@color/pink_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNamaBahan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Bahan"
                android:textSize="16sp"
                android:textColor="@color/text_main"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/txtDetailBahan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori • Lokasi"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:textColor="@color/pink_dark" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_edit"
            android:alpha="0.3"
            app:tint="@color/pink_primary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>