<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:fitsSystemWindows="true"
    android:padding="16dp">

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="vertical"
      android:gravity="center_horizontal">

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="@android:color/white"/>

    <ImageView
        android:id="@+id/detail_img_cover"
        android:layout_width="150dp"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/detail_tv_judul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:text="Judul Buku"
        android:layout_marginHorizontal="16dp"
        android:textAlignment="center"/>

    <TextView
        android:id="@+id/detail_tv_penulis_tahun"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:layout_marginTop="4dp"
        android:layout_marginHorizontal="16dp"
        android:text="Penulis - Tahun Terbit" />

    <TextView
        android:id="@+id/detail_tv_genre"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="italic"
        android:layout_marginTop="8dp"
        android:textColor="@android:color/darker_gray"
        android:text="Genre" />

    <TextView
        android:id="@+id/detail_tv_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="italic"
        android:layout_marginTop="8dp"
        android:textColor="@android:color/darker_gray"
        android:text="Rating" />

    <Button
        android:id="@+id/btn_like"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Tambahkan ke Favorite"
        android:backgroundTint="#FF4081"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#CCCCCC"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sinopsis"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detail_tv_blurb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:lineSpacingExtra="4dp"
        android:layout_marginHorizontal="16dp"
        android:text="Isi blurb..." />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:background="#CCCCCC"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Review Pengguna"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/detail_tv_review"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="italic"
        android:lineSpacingExtra="4dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:text="Isi review..." />

  </LinearLayout>
</ScrollView>