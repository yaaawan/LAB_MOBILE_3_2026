<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/iv_cover_preview"
            android:layout_width="140dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_book_placeholder" />

        <Button
            android:id="@+id/btn_pick_image"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pick_cover"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/et_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_title"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/et_author"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_author"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_year"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_year"
            android:inputType="number"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_genre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_genre"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_rating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_rating"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_review"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_blurb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_blurb"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_save_book"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_book"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>